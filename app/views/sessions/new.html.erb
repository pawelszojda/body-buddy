<% content_for :title, "Logowanie | Body Buddy" %>

<div class="mx-auto max-w-md">
  <div class="rounded-[2rem] border border-white/80 bg-white/85 p-8 shadow-lg shadow-slate-200/70 backdrop-blur">
    <div class="mb-8">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Bezpieczny dostęp</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-slate-950">Zaloguj się do Body Buddy</h1>
      <p class="mt-3 text-sm leading-6 text-slate-600">
        Użyj swojego konta, aby mieć dostęp do pomiarów, historii postępów i kolejnych funkcji aplikacji.
      </p>
    </div>

    <%= form_with url: session_path, class: "space-y-5 turbo-subtle-busy" do |form| %>
      <div class="space-y-2">
        <%= form.label :login, "E-mail lub nazwa użytkownika", class: "text-sm font-medium text-slate-700" %>
        <%= form.text_field :login, autofocus: true, autocomplete: "username", required: true, class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-400" %>
      </div>

      <div class="space-y-2">
        <%= form.label :password, "Hasło", class: "text-sm font-medium text-slate-700" %>
        <%= form.password_field :password, autocomplete: "current-password", required: true, class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-400" %>
      </div>

      <%= form.submit "Zaloguj się", data: { turbo_submits_with: "Logowanie..." }, class: "w-full rounded-2xl bg-slate-950 px-4 py-3 text-base font-medium text-white transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-800 active:scale-[0.99] disabled:translate-y-0 disabled:cursor-wait disabled:opacity-70" %>
    <% end %>

    <div class="mt-6 border-t border-slate-200 pt-5 text-center">
      <p class="text-sm text-slate-600">
        Nie masz jeszcze konta?
        <%= link_to "Załóż konto", new_user_path, class: "font-medium text-[#007aff] transition hover:text-[#005ecb]" %>
      </p>
    </div>
  </div>
</div>
