<% content_for :title, "Panel | Body Buddy" %>

<section class="space-y-6">
  <article class="overflow-hidden rounded-3xl border border-black/[0.04] bg-white shadow-[0_4px_12px_rgba(0,0,0,0.03)]">
    <div class="border-b border-black/[0.04] bg-[linear-gradient(135deg,rgba(255,255,255,1),rgba(246,248,252,1))] px-6 py-7 sm:px-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-medium text-[#86868b]"><%= dashboard_date_label %></p>
          <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[#1d1d1f] sm:text-5xl">
            Spokojny pulpit do codziennych pomiarów.
          </h1>
          <p class="mt-4 max-w-xl text-base leading-7 text-[#6e6e73]">
            Najważniejsze dane są na górze, a historia pozostaje lekka i czytelna jak dziennik zdrowia.
          </p>
        </div>

        <div class="w-full sm:w-auto sm:min-w-56">
          <%= turbo_frame_tag "quick_add_measurement_entry" do %>
            <%= render "measurement_entries/quick_add_button" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid gap-4 px-6 py-6 sm:px-8 lg:grid-cols-[1.35fr_0.65fr]">
      <article class="rounded-[1.75rem] bg-[#f7f8fb] p-6">
        <p class="text-sm font-medium uppercase tracking-[0.16em] text-[#86868b]">Ostatni zapis</p>

        <% if @latest_entry.present? %>
          <% weight_delta = MeasurementEntry.delta_between(@previous_entry, @latest_entry, :weight) %>
          <% body_fat_delta = MeasurementEntry.delta_between(@previous_entry, @latest_entry, :body_fat) %>

          <div class="mt-5 flex flex-wrap items-end gap-x-4 gap-y-3">
            <div>
              <p class="text-4xl font-semibold tracking-tight text-[#1d1d1f] sm:text-5xl">
                <%= number_with_precision(@latest_entry.weight, precision: 2, strip_insignificant_zeros: true) %>
                <span class="text-2xl font-medium text-[#86868b]">kg</span>
              </p>
              <p class="mt-2 text-sm text-[#86868b]"><%= measurement_entry_timestamp(@latest_entry.created_at) %></p>
            </div>

            <span class="inline-flex rounded-full px-4 py-2 text-sm font-medium <%= dashboard_metric_delta_classes(weight_delta) %>">
              <%= dashboard_metric_delta_pill(weight_delta, "kg") %>
            </span>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-black/[0.04] bg-white px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Tkanka tłuszczowa</p>
              <p class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]">
                <%= @latest_entry.body_fat.present? ? "#{number_with_precision(@latest_entry.body_fat, precision: 2, strip_insignificant_zeros: true)}%" : "Brak" %>
              </p>
              <% if body_fat_delta.present? %>
                <p class="mt-2 text-sm <%= dashboard_metric_delta_classes(body_fat_delta) %> bg-transparent px-0 py-0">
                  <%= dashboard_metric_delta_pill(body_fat_delta, "%") %>
                </p>
              <% end %>
            </div>

            <div class="rounded-2xl border border-black/[0.04] bg-white px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Szybki podgląd</p>
              <div class="mt-2 flex flex-wrap gap-2">
                <% @latest_entry.quick_status_badges.first(2).each do |badge| %>
                  <span class="rounded-full bg-[#f2f2f7] px-3 py-1.5 text-sm font-medium text-[#6e6e73]"><%= badge[:value] %></span>
                <% end %>
                <% if @latest_entry.quick_status_badges.empty? %>
                  <span class="text-sm text-[#86868b]">Dodaj nastrój lub sen w kolejnym wpisie.</span>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <div class="mt-5 rounded-[1.5rem] border border-dashed border-black/[0.08] bg-white px-5 py-6">
            <p class="text-lg font-medium tracking-tight text-[#1d1d1f]">Brak zapisanych pomiarów.</p>
            <p class="mt-2 text-sm leading-6 text-[#6e6e73]">
              Zacznij od pierwszego wpisu. Po zapisaniu tutaj pojawi się najnowsza waga, tkanka tłuszczowa i szybkie porównanie.
            </p>
          </div>
        <% end %>
      </article>

      <article class="rounded-[1.75rem] border border-black/[0.04] bg-white p-6">
        <p class="text-sm font-medium uppercase tracking-[0.16em] text-[#86868b]">Feed</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Historia ruchu</h2>

        <div class="mt-5 space-y-4">
          <div>
            <p class="text-sm text-[#86868b]">Wpisy</p>
            <p class="mt-1 text-3xl font-semibold tracking-tight text-[#1d1d1f]">
              <%= measurement_entries_count_label(@measurement_entries.count) %>
            </p>
          </div>

          <div class="rounded-2xl bg-[#f7f8fb] px-4 py-4 text-sm leading-6 text-[#6e6e73]">
            Każdy wpis ląduje poniżej w porządku chronologicznym, z szybkim podglądem nastroju, obwodów i zdjęć.
          </div>
        </div>
      </article>
    </div>
  </article>

  <section class="space-y-4" aria-labelledby="historia-pomiarow">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Timeline</p>
        <h2 id="historia-pomiarow" class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">
          Ostatnie pomiary
        </h2>
      </div>
      <p class="rounded-full border border-black/[0.04] bg-white px-4 py-2 text-sm font-medium text-[#6e6e73] shadow-[0_4px_12px_rgba(0,0,0,0.03)]">
        <%= measurement_entries_count_label(@measurement_entries.count) %>
      </p>
    </div>

    <div id="measurement_entries" class="space-y-3">
      <% if @measurement_entries.any? %>
        <%= render @measurement_entries %>
      <% else %>
        <article id="empty_measurement_entries_state" class="rounded-2xl border border-dashed border-black/[0.08] bg-white p-6 text-sm leading-6 text-[#6e6e73] shadow-[0_4px_12px_rgba(0,0,0,0.03)]">
          Nie masz jeszcze żadnych pomiarów. Dodaj pierwszy wpis, aby zbudować historię postępów.
        </article>
      <% end %>
    </div>
  </section>
</section>
