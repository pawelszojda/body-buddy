<% content_for :title, "Konto | Body Buddy" %>

<section class="space-y-6">
  <article class="overflow-hidden rounded-3xl border border-black/[0.04] bg-white shadow-[0_4px_12px_rgba(0,0,0,0.03)]">
    <div class="bg-[linear-gradient(135deg,rgba(255,255,255,1),rgba(247,248,251,1))] px-6 py-7 sm:px-8">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Konto</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[#1d1d1f] sm:text-5xl">
        <%= account_summary_value(current_user.username) %>
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-[#6e6e73]">
        Zarządzaj podstawowymi informacjami, danymi logowania i bezpieczeństwem konta.
      </p>
    </div>

    <div class="grid gap-4 border-t border-black/[0.04] px-6 py-6 sm:px-8 lg:grid-cols-3">
      <article class="rounded-2xl bg-[#f7f8fb] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Nazwa użytkownika</p>
        <p class="mt-2 text-xl font-semibold tracking-tight text-[#1d1d1f]"><%= account_summary_value(current_user.username) %></p>
      </article>

      <article class="rounded-2xl bg-[#f7f8fb] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">E-mail</p>
        <p class="mt-2 text-xl font-semibold tracking-tight text-[#1d1d1f]"><%= account_summary_value(current_user.email) %></p>
      </article>

      <article class="rounded-2xl bg-[#f7f8fb] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Liczba wpisów</p>
        <p class="mt-2 text-xl font-semibold tracking-tight text-[#1d1d1f]"><%= measurement_entries_count_label(current_user.measurement_entries.count) %></p>
      </article>
    </div>
  </article>

  <%= form_with model: current_user, url: account_path, method: :patch, class: "space-y-6 turbo-subtle-busy" do |form| %>
    <% if current_user.errors.any? %>
      <section class="rounded-[1.5rem] border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
        <p class="font-medium">Nie udało się zapisać zmian.</p>
        <ul class="mt-2 space-y-1">
          <% current_user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
      <section class="space-y-6">
        <article class="rounded-3xl border border-black/[0.04] bg-white p-6 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-8">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Podstawowe informacje</p>
          <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Profil</h2>

          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div>
              <%= form.label :username, "Nazwa użytkownika", class: "text-sm font-medium text-[#6e6e73]" %>
              <%= form.text_field :username, class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
            </div>

            <div>
              <%= form.label :email, "E-mail", class: "text-sm font-medium text-[#6e6e73]" %>
              <%= form.email_field :email, class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
            </div>
          </div>
        </article>

        <article class="rounded-3xl border border-black/[0.04] bg-white p-6 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-8">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Bezpieczeństwo</p>
          <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Zmiana hasła</h2>

          <div class="mt-6 grid gap-4">
            <div>
              <%= form.label :current_password, "Aktualne hasło", class: "text-sm font-medium text-[#6e6e73]" %>
              <%= form.password_field :current_password, value: nil, class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
              <p class="mt-2 text-xs leading-5 text-[#86868b]">Wymagane tylko wtedy, gdy zmieniasz hasło.</p>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <%= form.label :password, "Nowe hasło", class: "text-sm font-medium text-[#6e6e73]" %>
                <%= form.password_field :password, value: nil, class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
              </div>

              <div>
                <%= form.label :password_confirmation, "Potwierdź nowe hasło", class: "text-sm font-medium text-[#6e6e73]" %>
                <%= form.password_field :password_confirmation, value: nil, class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
              </div>
            </div>
          </div>
        </article>
      </section>

      <section class="space-y-6">
        <article class="rounded-3xl border border-black/[0.04] bg-white p-6 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-8">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Akcje</p>
          <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Zarządzanie kontem</h2>

          <div class="mt-6 flex flex-col gap-3">
            <%= form.submit "Zapisz zmiany", data: { turbo_submits_with: "Zapisywanie..." }, class: "inline-flex items-center justify-center rounded-full bg-[#1d1d1f] px-6 py-3 text-sm font-medium text-white shadow-[0_4px_12px_rgba(0,0,0,0.08)] transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-black active:scale-[0.99] disabled:translate-y-0 disabled:cursor-wait disabled:opacity-70" %>
          </div>
        </article>
      </section>
    </div>
  <% end %>

  <div class="grid gap-6 xl:grid-cols-[1fr_1fr]">
    <article class="rounded-3xl border border-black/[0.04] bg-white p-6 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-8">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Sesja</p>
      <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Wylogowanie</h2>
      <p class="mt-4 text-sm leading-6 text-[#6e6e73]">
        Zakończ bieżącą sesję na tym urządzeniu.
      </p>
      <%= button_to "Wyloguj", session_path, method: :delete, class: "mt-6 inline-flex items-center justify-center rounded-full bg-[#f2f2f7] px-5 py-3 text-sm font-medium text-[#1d1d1f] transition-all duration-200 ease-out hover:bg-black/[0.06]" %>
    </article>

    <article class="rounded-3xl border border-rose-200 bg-white p-6 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-8">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-rose-500">Strefa krytyczna</p>
      <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Usuń konto</h2>
      <p class="mt-4 text-sm leading-6 text-[#6e6e73]">
        To trwale usunie Twoje dane, pomiary oraz zdjęcia. Tej operacji nie można cofnąć.
      </p>
      <%= button_to "Usuń konto", account_path, method: :delete, data: { turbo_confirm: "Czy na pewno chcesz usunąć konto? Tej operacji nie można cofnąć." }, class: "mt-6 inline-flex items-center justify-center rounded-full bg-rose-600 px-5 py-3 text-sm font-medium text-white transition-all duration-200 ease-out hover:bg-rose-700" %>
    </article>
  </div>
</section>
