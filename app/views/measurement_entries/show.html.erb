<% content_for :title, "Pomiar | Body Buddy" %>

<section class="space-y-6">
  <article class="overflow-hidden rounded-3xl border border-black/[0.04] bg-white shadow-[0_4px_12px_rgba(0,0,0,0.03)]">
    <div class="bg-[linear-gradient(135deg,rgba(255,255,255,1),rgba(247,248,251,1))] px-6 py-7 sm:px-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <%= link_to "Wróć do historii", root_path, class: "text-sm font-medium text-[#86868b] transition hover:text-[#1d1d1f]" %>
          <p class="mt-4 text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Szczegóły wpisu</p>
          <h1 class="mt-2 text-4xl font-semibold tracking-tight text-[#1d1d1f] sm:text-5xl">
            <%= number_with_precision(@measurement_entry.weight, precision: 2, strip_insignificant_zeros: true) %>
            <span class="text-2xl font-medium text-[#86868b]">kg</span>
          </h1>
          <p class="mt-3 text-base leading-7 text-[#6e6e73]">
            Zapis z <%= measurement_entry_timestamp(@measurement_entry.created_at) %>
          </p>
        </div>

        <div class="flex flex-wrap gap-2">
          <% @measurement_entry.quick_status_badges.each do |badge| %>
            <span class="inline-flex items-center rounded-full border border-black/[0.04] bg-[#f7f8fb] px-3 py-1.5 text-sm font-medium text-[#6e6e73]">
              <%= badge[:label] %>: <%= badge[:value] %>
            </span>
          <% end %>

          <% if @measurement_entry.body_fat.present? %>
            <span class="inline-flex items-center rounded-full border border-black/[0.04] bg-[#f7f8fb] px-3 py-1.5 text-sm font-medium text-[#6e6e73]">
              Tkanka tłuszczowa: <%= number_with_precision(@measurement_entry.body_fat, precision: 2, strip_insignificant_zeros: true) %>%
            </span>
          <% end %>

          <% if @measurement_entry.stool_color.present? %>
            <span class="inline-flex items-center rounded-full border border-black/[0.04] bg-[#f7f8fb] px-3 py-1.5 text-sm font-medium text-[#6e6e73]">
              Kolor: <%= @measurement_entry.stool_color %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid gap-4 border-t border-black/[0.04] px-6 py-6 sm:px-8 lg:grid-cols-4">
      <article class="rounded-2xl bg-[#f7f8fb] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Waga</p>
        <p class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]">
          <%= number_with_precision(@measurement_entry.weight, precision: 2, strip_insignificant_zeros: true) %> kg
        </p>
      </article>

      <article class="rounded-2xl bg-[#f7f8fb] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Tkanka tłuszczowa</p>
        <p class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]">
          <%= @measurement_entry.body_fat.present? ? "#{number_with_precision(@measurement_entry.body_fat, precision: 2, strip_insignificant_zeros: true)}%" : "Brak" %>
        </p>
      </article>

      <article class="rounded-2xl bg-[#f7f8fb] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Nastrój</p>
        <p class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]"><%= @measurement_entry.mood_badge&.dig(:value) || "Brak" %></p>
      </article>

      <article class="rounded-2xl bg-[#f7f8fb] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Sen</p>
        <p class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]"><%= @measurement_entry.sleep_badge&.dig(:value) || "Brak" %></p>
      </article>
    </div>
  </article>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="space-y-6">
      <article class="rounded-3xl border border-black/[0.04] bg-white p-6 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-8">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Obwody</p>
            <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Pełny zestaw pomiarów</h2>
          </div>
        </div>

        <% if @measurement_entry.circumference_rows.any? %>
          <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <% @measurement_entry.circumference_rows.each do |row| %>
              <article class="rounded-2xl border border-black/[0.04] bg-[#f7f8fb] px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]"><%= row[:label] %></p>
                <p class="mt-2 text-lg font-medium text-[#1d1d1f]">
                  <%= number_with_precision(row[:value], precision: 2, strip_insignificant_zeros: true) %> cm
                </p>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="mt-6 rounded-2xl border border-dashed border-black/[0.08] bg-[#f7f8fb] px-5 py-4 text-sm leading-6 text-[#6e6e73]">
            Ten wpis nie zawiera jeszcze obwodów.
          </p>
        <% end %>
      </article>

      <article class="rounded-3xl border border-black/[0.04] bg-white p-6 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-8">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Notatka</p>
        <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Komentarz do dnia</h2>

        <% if @measurement_entry.note.present? %>
          <p class="mt-6 whitespace-pre-line text-base leading-8 text-[#3a3a3c]"><%= @measurement_entry.note %></p>
        <% else %>
          <p class="mt-6 rounded-2xl border border-dashed border-black/[0.08] bg-[#f7f8fb] px-5 py-4 text-sm leading-6 text-[#6e6e73]">
            Brak dodatkowej notatki do tego pomiaru.
          </p>
        <% end %>
      </article>
    </section>

    <section class="space-y-6">
      <article class="rounded-3xl border border-black/[0.04] bg-white p-6 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-8">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Stan dnia</p>
        <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Sygnały i samopoczucie</h2>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <article class="rounded-2xl border border-black/[0.04] bg-[#f7f8fb] px-5 py-4">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Nastrój</p>
            <p class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]"><%= @measurement_entry.mood_badge&.dig(:value) || "Brak" %></p>
          </article>

          <article class="rounded-2xl border border-black/[0.04] bg-[#f7f8fb] px-5 py-4">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Sen</p>
            <p class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]"><%= @measurement_entry.sleep_badge&.dig(:value) || "Brak" %></p>
          </article>

          <article class="rounded-2xl border border-black/[0.04] bg-[#f7f8fb] px-5 py-4 sm:col-span-2">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#86868b]">Skala Bristol</p>
            <p class="mt-2 text-2xl font-semibold tracking-tight text-[#1d1d1f]"><%= @measurement_entry.bristol_badge&.dig(:value) || "Brak" %></p>
          </article>
        </div>
      </article>

      <article data-controller="image-lightbox" class="rounded-3xl border border-black/[0.04] bg-white p-6 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-8">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Galeria</p>
        <h2 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Zdjęcia sylwetki</h2>

        <% if @measurement_entry.photo_gallery_items.any? { |item| item[:attachment].attached? } %>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            <% @measurement_entry.photo_gallery_items.each do |item| %>
              <article class="group relative overflow-hidden rounded-xl border border-black/[0.04] bg-[#f7f8fb]">
                <div class="aspect-[3/4] bg-[#ececf1]">
                  <% if item[:attachment].attached? %>
                    <button type="button"
                            class="block h-full w-full cursor-zoom-in"
                            data-action="click->image-lightbox#open"
                            data-full-src="<%= url_for(item[:attachment]) %>"
                            data-label="<%= item[:label] %>">
                      <%= image_tag item[:attachment], class: "h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.02]" %>
                    </button>
                    <div class="pointer-events-none absolute left-3 top-3 rounded-full bg-black/30 px-3 py-1 text-xs font-medium text-white backdrop-blur-sm">
                      <%= item[:label] %>
                    </div>
                  <% else %>
                    <div class="flex h-full items-center justify-center px-6 text-center text-sm text-[#86868b]">
                      Brak zdjęcia
                    </div>
                    <div class="pointer-events-none absolute left-3 top-3 rounded-full bg-black/20 px-3 py-1 text-xs font-medium text-white backdrop-blur-sm">
                      <%= item[:label] %>
                    </div>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>

          <dialog data-image-lightbox-target="dialog"
                  data-action="click->image-lightbox#closeOnBackdrop close->image-lightbox#reset"
                  class="m-auto w-[min(92vw,72rem)] max-w-5xl rounded-[2rem] border border-black/[0.06] bg-white/95 p-0 shadow-[0_20px_80px_rgba(0,0,0,0.24)] backdrop:bg-black/60">
            <div class="flex items-center justify-between border-b border-black/[0.06] px-5 py-4">
              <p data-image-lightbox-target="label" class="text-sm font-medium uppercase tracking-[0.16em] text-[#6e6e73]">Zdjęcie</p>
              <button type="button"
                      data-action="click->image-lightbox#close"
                      class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#f2f2f7] text-lg font-medium text-[#1d1d1f] transition hover:bg-black/[0.06]">
                ×
              </button>
            </div>
            <div class="bg-[#ececf1] p-4 sm:p-6">
              <img data-image-lightbox-target="image"
                   class="mx-auto max-h-[78vh] w-auto max-w-full rounded-[1.5rem] object-contain"
                   alt="Podgląd zdjęcia">
            </div>
          </dialog>
        <% else %>
          <p class="mt-6 rounded-2xl border border-dashed border-black/[0.08] bg-[#f7f8fb] px-5 py-4 text-sm leading-6 text-[#6e6e73]">
            Do tego wpisu nie dodano jeszcze żadnych zdjęć.
          </p>
        <% end %>
      </article>
    </section>
  </div>
</section>
