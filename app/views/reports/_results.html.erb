<% if first_entry.blank? || last_entry.blank? %>
  <article class="rounded-[2rem] border border-dashed border-slate-300 bg-white/75 p-8 text-sm leading-7 text-slate-500">
    Brak pomiarów w zakresie <strong><%= date_from.strftime("%d.%m.%Y") %></strong> - <strong><%= date_to.strftime("%d.%m.%Y") %></strong>.
  </article>
<% else %>
  <% comparison_rows = MeasurementEntry.comparison_rows(first_entry, last_entry) %>

  <section class="space-y-6">
    <article class="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-sm shadow-slate-200/60 backdrop-blur sm:p-8">
      <div class="grid gap-4 lg:grid-cols-2">
        <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-5 py-4">
          <p class="text-sm text-slate-500">Pierwszy wpis</p>
          <p class="mt-2 text-2xl font-semibold tracking-[-0.03em] text-slate-950">
            <%= measurement_metric_value(first_entry.weight, "kg") %>
          </p>
          <p class="mt-2 text-sm text-slate-500"><%= measurement_entry_timestamp(first_entry.created_at) %></p>
          <%= link_to "Zobacz wpis", measurement_entry_path(first_entry), class: "mt-4 inline-flex text-sm font-medium text-slate-600 transition hover:text-slate-950" %>
        </article>

        <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-5 py-4">
          <p class="text-sm text-slate-500">Ostatni wpis</p>
          <p class="mt-2 text-2xl font-semibold tracking-[-0.03em] text-slate-950">
            <%= measurement_metric_value(last_entry.weight, "kg") %>
          </p>
          <p class="mt-2 text-sm text-slate-500"><%= measurement_entry_timestamp(last_entry.created_at) %></p>
          <%= link_to "Zobacz wpis", measurement_entry_path(last_entry), class: "mt-4 inline-flex text-sm font-medium text-slate-600 transition hover:text-slate-950" %>
        </article>
      </div>
    </article>

    <article class="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-sm shadow-slate-200/60 backdrop-blur sm:p-8">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Macierz zmian</p>
      <h2 class="mt-1 text-2xl font-semibold tracking-[-0.03em] text-slate-950">Porównanie metryk</h2>

      <div class="mt-6 overflow-hidden rounded-[1.5rem] border border-slate-200">
        <div class="grid grid-cols-4 gap-4 bg-slate-50 px-5 py-3 text-xs font-medium uppercase tracking-[0.18em] text-slate-500">
          <span>Parametr</span>
          <span>Pierwszy</span>
          <span>Ostatni</span>
          <span>Delta</span>
        </div>

        <% comparison_rows.each do |row| %>
          <div class="grid grid-cols-4 gap-4 border-t border-slate-200 bg-white px-5 py-4 text-sm sm:text-base">
            <span class="font-medium text-slate-700"><%= row[:label] %></span>
            <span class="text-slate-950"><%= measurement_metric_value(row[:first_value], row[:unit]) %></span>
            <span class="text-slate-950"><%= measurement_metric_value(row[:last_value], row[:unit]) %></span>
            <span class="font-semibold <%= comparison_delta_classes(row) %>"><%= measurement_delta_value(row[:delta], row[:unit]) %></span>
          </div>
        <% end %>
      </div>
    </article>

    <article class="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-sm shadow-slate-200/60 backdrop-blur sm:p-8">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Porównanie wizualne</p>
      <h2 class="mt-1 text-2xl font-semibold tracking-[-0.03em] text-slate-950">Zdjęcia: pierwszy vs ostatni</h2>

      <div class="mt-6 grid gap-5 xl:grid-cols-3">
        <% [
          { label: "Przód", first: first_entry.photo_front, last: last_entry.photo_front },
          { label: "Tył", first: first_entry.photo_back, last: last_entry.photo_back },
          { label: "Bok", first: first_entry.photo_side, last: last_entry.photo_side }
        ].each do |comparison| %>
          <article class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm font-medium uppercase tracking-[0.18em] text-slate-500"><%= comparison[:label] %></p>

            <div class="mt-4 grid grid-cols-2 gap-3">
              <div class="overflow-hidden rounded-[1.25rem] border border-slate-200 bg-white">
                <div class="aspect-[4/5] bg-slate-100">
                  <% if comparison[:first].attached? %>
                    <%= image_tag comparison[:first], class: "h-full w-full object-cover" %>
                  <% else %>
                    <div class="flex h-full items-center justify-center px-4 text-center text-sm text-slate-400">Brak zdjęcia</div>
                  <% end %>
                </div>
                <div class="border-t border-slate-200 px-3 py-2 text-sm font-medium text-slate-600">Pierwszy</div>
              </div>

              <div class="overflow-hidden rounded-[1.25rem] border border-slate-200 bg-white">
                <div class="aspect-[4/5] bg-slate-100">
                  <% if comparison[:last].attached? %>
                    <%= image_tag comparison[:last], class: "h-full w-full object-cover" %>
                  <% else %>
                    <div class="flex h-full items-center justify-center px-4 text-center text-sm text-slate-400">Brak zdjęcia</div>
                  <% end %>
                </div>
                <div class="border-t border-slate-200 px-3 py-2 text-sm font-medium text-slate-600">Ostatni</div>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </article>
  </section>
<% end %>
