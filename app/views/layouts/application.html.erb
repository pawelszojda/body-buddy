<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Body Buddy" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Body Buddy">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-[#f5f5f7] text-slate-900 antialiased">
    <div class="min-h-screen font-['-apple-system','BlinkMacSystemFont','SF_Pro_Display','SF_Pro_Text','Segoe_UI',sans-serif]">
      <header class="sticky top-0 z-10 border-b border-white/60 bg-[#f5f5f7]/90 backdrop-blur-xl">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <div>
            <%= link_to "Body Buddy", root_path, class: "text-lg font-semibold tracking-[-0.02em] text-slate-950" %>
          </div>

          <nav class="flex items-center gap-2 rounded-full border border-white/80 bg-white/80 p-1 text-sm text-slate-600 shadow-sm shadow-slate-200/60">
            <%= link_to "Panel", root_path, class: "rounded-full px-4 py-2 transition hover:bg-slate-100 hover:text-slate-900 #{current_page?(root_path) ? 'bg-slate-900 text-white hover:bg-slate-900 hover:text-white' : ''}" %>

            <% if user_signed_in? %>
              <%= button_to "Wyloguj", session_path, method: :delete, class: "rounded-full px-4 py-2 transition hover:bg-slate-100 hover:text-slate-900", form_class: "contents" %>
            <% else %>
              <%= link_to "Zaloguj", new_session_path, class: "rounded-full px-4 py-2 transition hover:bg-slate-100 hover:text-slate-900 #{current_page?(new_session_path) ? 'bg-slate-900 text-white hover:bg-slate-900 hover:text-white' : ''}" %>
            <% end %>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
        <% flash.each do |type, message| %>
          <% flash_classes = type.to_s == "notice" ? "border-emerald-200 bg-emerald-50 text-emerald-900" : "border-amber-200 bg-amber-50 text-amber-900" %>
          <div class="mb-6 rounded-2xl border px-4 py-3 text-sm shadow-sm <%= flash_classes %>">
            <%= message %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
