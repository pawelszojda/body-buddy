<%= form_with model: measurement_entry, class: "space-y-5 turbo-subtle-busy" do |form| %>
  <%= hidden_field_tag :return_to, local_assigns[:return_to] %>
  <% if measurement_entry.errors.any? %>
    <section class="rounded-[1.5rem] border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
      <p class="font-medium">Nie udało się zapisać pomiaru.</p>
      <ul class="mt-2 space-y-1">
        <% measurement_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <section class="rounded-[1.75rem] bg-[linear-gradient(135deg,rgba(255,255,255,1),rgba(247,248,251,1))] px-5 py-5">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Szybki wpis</p>
    <h2 class="mt-2 text-3xl font-semibold tracking-tight text-[#1d1d1f]">Nowy pomiar</h2>
    <p class="mt-2 max-w-xl text-sm leading-6 text-[#6e6e73]">
      Uzupełnij najważniejsze dane. Formularz został podzielony jak arkusz w aplikacji Zdrowie.
    </p>
  </section>

  <section class="rounded-[1.75rem] border border-black/[0.04] bg-white p-5 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-6">
    <div class="mb-5">
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-[#86868b]">Podstawowe pomiary</p>
      <h3 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Rdzeń wpisu</h3>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= form.label :weight, "Waga (kg)", class: "text-sm font-medium text-[#6e6e73]" %>
        <%= form.number_field :weight, step: "0.01", min: "0", required: true, inputmode: "decimal", placeholder: "82.4", class: "mt-2 block w-full rounded-[1.75rem] border border-black/[0.05] bg-[#f7f8fb] px-5 py-5 text-4xl font-semibold tracking-tight text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
      </div>

      <div>
        <%= form.label :body_fat, "Tkanka tłuszczowa (%)", class: "text-sm font-medium text-[#6e6e73]" %>
        <%= form.number_field :body_fat, step: "0.01", min: "0", max: "100", inputmode: "decimal", class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
      </div>
    </div>
  </section>

  <section class="rounded-[1.75rem] border border-black/[0.04] bg-white p-5 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-6">
    <div class="mb-5">
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-[#86868b]">Obwody ciała</p>
      <h3 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Skan sylwetki</h3>
    </div>

    <div class="grid auto-rows-fr gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <% [
        [:calf, "Łydka"],
        [:thigh, "Udo"],
        [:buttocks, "Pośladki"],
        [:waist, "Pas"],
        [:abdomen, "Brzuch"],
        [:chest, "Klatka piersiowa"],
        [:biceps, "Biceps"],
        [:forearm, "Przedramię"]
      ].each do |field, label| %>
        <div class="flex h-full flex-col">
          <%= form.label field, "#{label} (cm)", class: "flex min-h-10 items-end text-sm font-medium text-[#6e6e73]" %>
          <%= form.number_field field, step: "0.01", min: "0", inputmode: "decimal", class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="rounded-[1.75rem] border border-black/[0.04] bg-white p-5 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-6 space-y-5">
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-[#86868b]">Samopoczucie i zdrowie</p>
      <h3 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Jak wyglądał ten dzień?</h3>
    </div>

    <%= render "measurement_entries/radio_picker",
               form: form,
               field: :mood,
               legend: "Nastrój",
               hint: "Wybierz 1 z 5",
               options: [
                 [ "😞", 1 ],
                 [ "😐", 2 ],
                 [ "🙂", 3 ],
                 [ "😄", 4 ],
                 [ "🤩", 5 ]
               ] %>

    <%= render "measurement_entries/radio_picker",
               form: form,
               field: :sleep_quality,
               legend: "Sen",
               hint: "Ocena nocy",
               options: [
                 [ "😴", 1 ],
                 [ "🥱", 2 ],
                 [ "🙂", 3 ],
                 [ "🌙", 4 ],
                 [ "✨", 5 ]
               ] %>

    <%= render "measurement_entries/radio_picker",
               form: form,
               field: :bristol_stool_type,
               legend: "Skala Bristol",
               hint: "Typ stolca",
               variant: :bristol,
               options: [
                 { label: "1", value: 1, description: MeasurementEntry::BRISTOL_DESCRIPTIONS[1] },
                 { label: "2", value: 2, description: MeasurementEntry::BRISTOL_DESCRIPTIONS[2] },
                 { label: "3", value: 3, description: MeasurementEntry::BRISTOL_DESCRIPTIONS[3] },
                 { label: "4", value: 4, description: MeasurementEntry::BRISTOL_DESCRIPTIONS[4] },
                 { label: "5", value: 5, description: MeasurementEntry::BRISTOL_DESCRIPTIONS[5] },
                 { label: "6", value: 6, description: MeasurementEntry::BRISTOL_DESCRIPTIONS[6] },
                 { label: "7", value: 7, description: MeasurementEntry::BRISTOL_DESCRIPTIONS[7] }
               ] %>

    <%= render "measurement_entries/radio_picker",
               form: form,
               field: :stool_color,
               legend: "Kolor stolca",
               hint: "Najbliższy odcień",
               variant: :color,
               options: MeasurementEntry::STOOL_COLOR_OPTIONS %>
  </section>

  <section class="rounded-[1.75rem] border border-black/[0.04] bg-white p-5 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-6">
    <div class="mb-5">
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-[#86868b]">Zdjęcia progresu</p>
      <h3 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Kadry jak z rolki aparatu</h3>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
      <%= render "measurement_entries/photo_input", form: form, field: :photo_front, label: "Przód" %>
      <%= render "measurement_entries/photo_input", form: form, field: :photo_back, label: "Tył" %>
      <%= render "measurement_entries/photo_input", form: form, field: :photo_side, label: "Bok" %>
    </div>
  </section>

  <section class="rounded-[1.75rem] border border-black/[0.04] bg-white p-5 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-6">
    <div class="mb-5">
      <p class="text-sm font-medium uppercase tracking-[0.16em] text-[#86868b]">Notatka</p>
      <h3 class="mt-1 text-2xl font-semibold tracking-tight text-[#1d1d1f]">Kilka słów o dniu</h3>
    </div>

    <%= form.label :note, "Komentarz", class: "text-sm font-medium text-[#6e6e73]" %>
    <%= form.text_area :note, rows: 4, class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
  </section>

  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm leading-6 text-[#86868b]">Po zapisie nowy wpis pojawi się od razu na górze osi czasu.</p>
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
      <%= link_to "Porzuć", local_assigns[:return_to].presence || root_path, class: "inline-flex items-center justify-center rounded-full bg-[#f2f2f7] px-5 py-3 text-sm font-medium text-[#1d1d1f] transition-all duration-200 ease-out hover:bg-black/[0.06]" %>
      <%= form.submit "Zapisz pomiar", data: { turbo_submits_with: "Zapisywanie..." }, class: "inline-flex items-center justify-center rounded-full bg-[#1d1d1f] px-6 py-3 text-sm font-medium text-white shadow-[0_4px_12px_rgba(0,0,0,0.08)] transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-black active:scale-[0.99] disabled:translate-y-0 disabled:cursor-wait disabled:opacity-70" %>
    </div>
  </div>
<% end %>
