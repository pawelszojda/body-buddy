<% content_for :title, "Logowanie | Body Buddy" %>

<div class="rounded-2xl border border-black/[0.04] bg-white p-8 shadow-[0_12px_40px_rgba(0,0,0,0.06)] sm:p-10">
  <div class="mb-8 text-center">
    <p class="text-sm font-medium uppercase tracking-[0.22em] text-[#86868b]">BBody Buddy</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight text-[#1d1d1f]">Witaj z powrotem!</h1>
  </div>

  <%= form_with url: session_path, class: "space-y-5 turbo-subtle-busy" do |form| %>
    <div class="space-y-2">
      <%= form.label :login, "E-mail lub nazwa użytkownika", class: "sr-only" %>
      <%= form.text_field :login, autofocus: true, autocomplete: "username", required: true, placeholder: "E-mail lub nazwa użytkownika", class: "block w-full rounded-full border border-[#d2d2d7] bg-white px-5 py-3.5 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out placeholder:text-[#86868b] focus:border-black/20 focus:ring-1 focus:ring-black/20" %>
    </div>

    <div class="space-y-2">
      <%= form.label :password, "Hasło", class: "sr-only" %>
      <%= form.password_field :password, autocomplete: "current-password", required: true, placeholder: "Hasło", class: "block w-full rounded-full border border-[#d2d2d7] bg-white px-5 py-3.5 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out placeholder:text-[#86868b] focus:border-black/20 focus:ring-1 focus:ring-black/20" %>
    </div>

    <%= form.submit "Zaloguj się", data: { turbo_submits_with: "Logowanie..." }, class: "w-full rounded-full bg-[#30b0c7] px-4 py-3.5 text-base font-medium text-white shadow-[0_10px_24px_rgba(48,176,199,0.22)] transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-[#279db2] active:scale-[0.99] disabled:translate-y-0 disabled:cursor-wait disabled:opacity-70" %>
  <% end %>

  <div class="mt-6 border-t border-[#ececf1] pt-5 text-center">
    <p class="text-sm text-[#6e6e73]">
      Nie masz jeszcze konta?
      <%= link_to "Załóż konto", new_user_path, class: "font-medium text-[#30b0c7] transition hover:text-[#279db2]" %>
    </p>
  </div>
</div>
