<% content_for :title, "Raport postępów | Body Buddy" %>

<section class="space-y-6">
  <article class="overflow-hidden rounded-3xl border border-black/[0.04] bg-white shadow-[0_4px_12px_rgba(0,0,0,0.03)]">
    <div class="bg-[linear-gradient(135deg,rgba(255,255,255,1),rgba(247,248,251,1))] px-6 py-7 sm:px-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#86868b]">Moduł postępów</p>
          <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[#1d1d1f] sm:text-5xl">
            Porównaj pierwszy i ostatni pomiar w wybranym oknie czasu.
          </h1>
          <p class="mt-4 text-base leading-7 text-[#6e6e73]">
            Zmień zakres dat, aby przejrzeć progres jak w czytelnym arkuszu kontroli zdrowia.
          </p>
        </div>

        <div class="w-full lg:max-w-[30rem]">
          <%= form_with url: report_path, method: :get, class: "rounded-[1.75rem] border border-black/[0.04] bg-white/90 p-4 shadow-[0_4px_12px_rgba(0,0,0,0.03)] sm:p-5", data: { turbo_frame: "report_results" } do |form| %>
            <div class="grid gap-3 sm:grid-cols-2">
              <div>
                <%= form.label :date_from, "Od", class: "text-sm font-medium text-[#6e6e73]" %>
                <%= form.date_field :date_from, value: @date_from, class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
              </div>

              <div>
                <%= form.label :date_to, "Do", class: "text-sm font-medium text-[#6e6e73]" %>
                <%= form.date_field :date_to, value: @date_to, class: "mt-2 block w-full rounded-[1.25rem] border border-black/[0.05] bg-[#f7f8fb] px-4 py-3 text-base text-[#1d1d1f] outline-none transition-all duration-200 ease-out focus:border-black/20 focus:bg-white focus:ring-1 focus:ring-black/20" %>
              </div>
            </div>

            <div class="mt-4 flex items-center justify-between gap-4">
              <p class="text-sm text-[#86868b]">Zakres: <%= report_date_range_label(@date_from, @date_to) %></p>
              <%= form.submit "Pokaż porównanie", class: "inline-flex items-center justify-center rounded-full bg-[#1d1d1f] px-5 py-3 text-sm font-medium text-white shadow-[0_4px_12px_rgba(0,0,0,0.08)] transition-all duration-200 ease-out hover:bg-black" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </article>

  <%= turbo_frame_tag "report_results" do %>
    <%= render "results", first_entry: @first_entry, last_entry: @last_entry, date_from: @date_from, date_to: @date_to %>
  <% end %>
</section>
