<% content_for :title, "Raport postępów | Body Buddy" %>

<section class="space-y-6">
  <article class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm shadow-slate-200/70 backdrop-blur sm:p-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Moduł postępów</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-4xl">
          Porównaj pierwszy i ostatni pomiar w wybranym zakresie.
        </h1>
        <p class="mt-4 text-base leading-7 text-slate-600">
          Wybierz przedział dat, aby zobaczyć zmianę w metrykach i zestawienie zdjęć sylwetki bez przeładowania całej strony.
        </p>
      </div>

      <%= form_with url: report_path, method: :get, class: "grid gap-3 sm:grid-cols-2 lg:min-w-[28rem]", data: { turbo_frame: "report_results" } do |form| %>
        <div>
          <%= form.label :date_from, "Od", class: "text-sm font-medium text-slate-700" %>
          <%= form.date_field :date_from, value: @date_from, class: "mt-2 block w-full rounded-[1.25rem] border border-slate-200 bg-slate-50 px-4 py-3 text-base text-slate-900 outline-none transition focus:border-slate-400 focus:bg-white" %>
        </div>

        <div>
          <%= form.label :date_to, "Do", class: "text-sm font-medium text-slate-700" %>
          <%= form.date_field :date_to, value: @date_to, class: "mt-2 block w-full rounded-[1.25rem] border border-slate-200 bg-slate-50 px-4 py-3 text-base text-slate-900 outline-none transition focus:border-slate-400 focus:bg-white" %>
        </div>

        <div class="sm:col-span-2">
          <%= form.submit "Pokaż porównanie", class: "inline-flex items-center justify-center rounded-[1.5rem] bg-slate-950 px-5 py-4 text-base font-medium text-white shadow-lg shadow-slate-300/60 transition hover:bg-slate-800" %>
        </div>
      <% end %>
    </div>
  </article>

  <%= turbo_frame_tag "report_results" do %>
    <%= render "results", first_entry: @first_entry, last_entry: @last_entry, date_from: @date_from, date_to: @date_to %>
  <% end %>
</section>
