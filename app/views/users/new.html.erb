<% content_for :title, "Rejestracja | Body Buddy" %>

<div class="mx-auto max-w-md">
  <div class="rounded-[2rem] border border-white/80 bg-white/85 p-8 shadow-lg shadow-slate-200/70 backdrop-blur">
    <div class="mb-8">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Nowe konto</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-slate-950">Załóż konto w Body Buddy</h1>
      <p class="mt-3 text-sm leading-6 text-slate-600">
        Utwórz konto, aby zapisywać pomiary, porównywać postępy i zarządzać swoją historią.
      </p>
    </div>

    <%= form_with model: @user, class: "space-y-5 turbo-subtle-busy" do |form| %>
      <% if @user.errors.any? %>
        <section class="rounded-[1.5rem] border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
          <p class="font-medium">Nie udało się utworzyć konta.</p>
          <ul class="mt-2 space-y-1">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </section>
      <% end %>

      <div class="space-y-2">
        <%= form.label :username, "Nazwa użytkownika", class: "text-sm font-medium text-slate-700" %>
        <%= form.text_field :username, autofocus: true, autocomplete: "username", required: true, class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-400" %>
      </div>

      <div class="space-y-2">
        <%= form.label :email, "E-mail", class: "text-sm font-medium text-slate-700" %>
        <%= form.email_field :email, autocomplete: "email", required: true, class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-400" %>
      </div>

      <div class="space-y-2">
        <%= form.label :password, "Hasło", class: "text-sm font-medium text-slate-700" %>
        <%= form.password_field :password, autocomplete: "new-password", required: true, class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-400" %>
      </div>

      <div class="space-y-2">
        <%= form.label :password_confirmation, "Potwierdź hasło", class: "text-sm font-medium text-slate-700" %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-400" %>
      </div>

      <%= form.submit "Utwórz konto", data: { turbo_submits_with: "Tworzenie konta..." }, class: "w-full rounded-2xl bg-slate-950 px-4 py-3 text-base font-medium text-white transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-800 active:scale-[0.99] disabled:translate-y-0 disabled:cursor-wait disabled:opacity-70" %>
    <% end %>

    <div class="mt-6 border-t border-slate-200 pt-5 text-center">
      <p class="text-sm text-slate-600">
        Masz już konto?
        <%= link_to "Zaloguj się", new_session_path, class: "font-medium text-[#007aff] transition hover:text-[#005ecb]" %>
      </p>
    </div>
  </div>
</div>
