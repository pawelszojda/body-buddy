<%= link_to measurement_entry_path(measurement_entry), id: dom_id(measurement_entry), class: "group block rounded-2xl border border-black/[0.04] bg-white p-4 shadow-[0_4px_12px_rgba(0,0,0,0.03)] transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-black/[0.08] sm:p-5 #{local_assigns[:animate_on_insert] ? 'animate-card-in' : ''}" do %>
  <div class="flex items-start gap-4">
    <div class="min-w-0 flex-1">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div class="min-w-0">
          <p class="text-sm text-[#86868b]">
            <%= measurement_entry_timestamp(measurement_entry.created_at) %>
          </p>
          <div class="mt-3 flex items-end gap-3">
            <div class="text-3xl font-semibold tracking-tight text-[#1d1d1f] transition group-hover:text-[#007aff]">
              <%= number_with_precision(measurement_entry.weight, precision: 2, strip_insignificant_zeros: true) %>
              <span class="text-lg font-medium text-[#86868b]">kg</span>
            </div>

            <% if measurement_entry.body_fat.present? %>
              <span class="rounded-full bg-[#f2f2f7] px-3 py-1 text-sm font-medium text-[#6e6e73]">
                <%= number_with_precision(measurement_entry.body_fat, precision: 2, strip_insignificant_zeros: true) %>% tłuszczu
              </span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        <% measurement_entry.circumference_badges.each do |badge| %>
          <span class="inline-flex items-center rounded-full border border-black/[0.04] bg-[#f8f8fa] px-3 py-1.5 text-xs font-medium text-[#6e6e73]">
            <%= badge[:label] %>
          </span>
        <% end %>

        <% measurement_entry.quick_status_badges.each do |badge| %>
          <span class="inline-flex items-center rounded-full border border-black/[0.04] bg-[#f8f8fa] px-3 py-1.5 text-xs font-medium text-[#6e6e73]">
            <%= badge[:value] %>
          </span>
        <% end %>

        <% remaining_circumferences = measurement_entry.circumference_rows.count - measurement_entry.circumference_badges.count %>
        <% if remaining_circumferences.positive? %>
          <span class="inline-flex items-center rounded-full border border-black/[0.04] bg-[#f8f8fa] px-3 py-1.5 text-xs font-medium text-[#6e6e73]">
            +<%= remaining_circumferences %> obw.
          </span>
        <% end %>
      </div>
    </div>

    <% if measurement_entry.attached_photos.any? %>
      <div class="hidden shrink-0 sm:block">
        <div class="flex -space-x-3">
          <% measurement_entry.attached_photos.first(3).each do |photo| %>
            <div class="h-16 w-12 overflow-hidden rounded-xl border border-white bg-[#f2f2f7] shadow-[0_4px_12px_rgba(0,0,0,0.06)]">
              <%= image_tag photo, class: "h-full w-full object-cover" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
